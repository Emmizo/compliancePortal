flowchart LR
  subgraph clients [Clients]
    Browser[Browser SPA]
  end
  subgraph edge [Optional edge]
    Nginx[Nginx reverse proxy]
  end
  subgraph backend [Spring Boot]
    API[REST /api]
    WS[STOMP /ws realtime]
    SVC[Services + state machine]
    SEC[JWT security filters]
  end
  subgraph data [Persistence]
    DB[(MySQL)]
    FS[Document storage]

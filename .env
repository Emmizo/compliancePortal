# Copy to .env and adjust before running `docker compose up`.
# Defaults are safe for local development only -- never deploy them as-is.

# --- Database ----------------------------------------------------------------
MYSQL_DATABASE=compliance_portal
MYSQL_USER=portal
MYSQL_PASSWORD=portal_dev
MYSQL_ROOT_PASSWORD=root_dev

# --- JWT ---------------------------------------------------------------------
# HS256 signing secret. MUST be at least 32 bytes (256 bits) and high-entropy.
# Generate with:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_replace_with_a_long_random_signing_key_for_HS256_min_32_bytes_xxxxxxxx
JWT_EXPIRATION_MINUTES=120

# --- Seed data ---------------------------------------------------------------
# When true, DataInitializer creates one user per role plus two seeded
# applications on first boot (idempotent, safe to leave on).
SEED_ENABLED: ${SEED_ENABLED:-true}

# --- CORS --------------------------------------------------------------------
# Comma-separated list. Defaults cover the dockerised UI on :8080 and the
# Vite dev server on :5173. In production point this at your real origin.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# --- Host ports --------------------------------------------------------------
# 5173 chosen so `docker compose up` does not collide with a typical local
# Spring Boot run on 8080. Change to 8080 in production deployments.
FRONTEND_HOST_PORT=5173
